# ─── Voxtral Stack — Environment Variables ───────────────────────────────────
# Copy to .env and fill in your values before running docker compose up

# !! REQUIRED !!
# HuggingFace token with access to mistralai/Voxtral-Mini-4B-Realtime-2602
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE

# ─── Optional overrides ───────────────────────────────────────────────────────

# vLLM max context length (each token = 80ms audio).
# 45000 ≈ 1h  |  131072 ≈ 3h (default, uses more VRAM for RoPE pre-alloc)
# VLLM_MAX_MODEL_LEN=45000

# GPU memory utilization (0.0–1.0). 0.90 leaves ~1.6 GB headroom on 16 GB A4000
# VLLM_GPU_MEMORY_UTILIZATION=0.90
