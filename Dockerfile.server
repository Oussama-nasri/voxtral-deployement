# ─────────────────────────────────────────────────────────────────────────────
# Voxtral Mini 4B Realtime — vLLM Server Image
# Base: official vLLM nightly (CUDA 12.4, uses `vllm serve` entrypoint)
# Target GPU: NVIDIA RTX A4000 (Ampere sm_86, 16 GB VRAM)
# ─────────────────────────────────────────────────────────────────────────────
FROM vllm/vllm-openai:nightly

# --- System deps ---
RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg \
        libsndfile1 \
        sox \
        curl \
    && rm -rf /var/lib/apt/lists/*

# --- Find the real Python binary and install audio deps ---
# The nightly image uses uv-managed Python; we must pass --system so uv
# installs into the system site-packages rather than requiring a venv.
# We also ensure pip is available as a fallback.
RUN uv pip install --system --no-cache \
        soxr \
        librosa \
        soundfile \
        "mistral-common>=1.9.0" \
        "transformers>=5.2.0"

# --- Model cache ---
ENV HF_HOME=/models/huggingface
ENV TRANSFORMERS_CACHE=/models/huggingface
VOLUME ["/models"]

# --- A4000 tuning ---
ENV VLLM_DISABLE_COMPILE_CACHE=1
ENV CUDA_VISIBLE_DEVICES=0

EXPOSE 8000

# ─── Entrypoint ───────────────────────────────────────────────────────────────
# The vllm/vllm-openai nightly image ships with:
#   ENTRYPOINT ["vllm", "serve"]
# We do NOT override ENTRYPOINT — we only provide CMD arguments.
#
# Flags tuned for A4000 (16 GB):
#   --max-model-len 45000           → ~1h audio; reduces RoPE pre-alloc vs 131k default
#   --gpu-memory-utilization 0.90   → leaves ~1.6 GB headroom
#   --dtype bfloat16                → matches Voxtral weights
#   cudagraph_mode PIECEWISE        → avoids OOM from full static capture on 16GB
CMD [ \
    "mistralai/Voxtral-Mini-4B-Realtime-2602", \
    "--dtype",                   "bfloat16", \
    "--max-model-len",           "20000", \
    "--gpu-memory-utilization",  "0.80", \
    "--compilation_config",      "{\"cudagraph_mode\": \"PIECEWISE\"}", \
    "--host",                    "0.0.0.0", \
    "--port",                    "8000" \
]